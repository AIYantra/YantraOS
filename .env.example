# Split these values at runtime into root:root 0600 service files:
# /etc/yantra/daemon.env: control, Azure, deployment, telemetry, node values.
# /etc/yantra/telegram.env: control token and Telegram values only.
YANTRA_CONTROL_TOKEN=<required-random-control-token>
AZURE_OPENAI_ENDPOINT=<azure-openai-endpoint>
AZURE_OPENAI_API_KEY=<azure-openai-api-key>
AZURE_OPENAI_DEPLOYMENT_NAME=<azure-openai-deployment-name>
AZURE_DEPLOYMENT_LUNA=<azure-luna-deployment-name>
AZURE_DEPLOYMENT_TERRA=<azure-terra-deployment-name>
AZURE_DEPLOYMENT_SOL=<azure-sol-deployment-name>
TELEGRAM_BOT_TOKEN=<telegram-bot-token>
TELEGRAM_OPERATOR_CHAT_ID=<telegram-operator-chat-id>
YANTRA_TELEMETRY_ENDPOINT=<https-telemetry-endpoint>
YANTRA_TELEMETRY_TOKEN=<telemetry-bearer-token>
YANTRA_NODE_ID=<unique-node-id>

# Compose runs as this host identity; it must match the socket and data owners.
YANTRA_UID=<host-uid>
YANTRA_GID=<host-gid>

# Browser actions are disabled until a separately isolated browser service is
# implemented; there is no environment-variable bypass.
