**
!Dockerfile.daemon
!.dockerignore
!requirements.txt
!requirements.lock
!core/
!core/**
!scripts/
!scripts/**

# Never re-include credentials or runtime state from allowed source trees.
**/.env
**/.env.*
**/*.env
**/*.env.*
**/*secret*
**/*credential*
**/*.pem
**/*.pub
**/*.key
**/*.p12
**/*.pfx
**/*.crt
**/*.csr
**/*.kdbx
**/*.db
**/*.sqlite
**/*.sqlite3

# Repository metadata, local environments, and caches.
**/.git
**/.git/**
**/venv
**/venv/**
**/.venv
**/.venv/**
**/__pycache__
**/__pycache__/**
**/.pytest_cache
**/.pytest_cache/**
**/.mypy_cache
**/.mypy_cache/**
**/.ruff_cache
**/.ruff_cache/**
**/*.py[cod]
**/*.log
**/.coverage*

# Build and deployment artifacts.
**/out
**/out/**
**/work
**/work/**
**/build
**/build/**
**/dist
**/dist/**
**/*.iso
**/*.vhd
**/*.raw
**/*.qcow2
**/*.squashfs
**/*.whl
**/*.tar.gz
